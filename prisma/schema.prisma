generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EXPORTER        // İhracatçı
  MANUFACTURER    // Üretici
  SELLER          // Satıcı
  LOGISTICS       // Lojistikçi
  WAREHOUSE       // Depolama
  TRADE_EXPERT    // Dış Ticaret Uzmanı
  ICC_EXPERT      // ICC Uzmanı
  FINANCIAL_ADV   // Mali Müşavir
  ACCOUNTING      // Muhasebe
  INSURER         // Sigortacı
}

enum TradeStatus {
  PENDING
  REVIEWING
  QUOTING
  LOGISTICS_APPROVED
  DOCUMENTS_PENDING
  DOCUMENTS_APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum DocumentType {
  COMMERCIAL_INVOICE
  BILL_OF_LADING
  CUSTOMS_DECLARATION
  INSURANCE_POLICY
  OTHER
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(EXPORTER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // İlişkiler
  tradeRequests TradeRequest[] @relation("ExporterRequests")
  quotes        LogisticsQuote[]
  documents     Document[]
}

model TradeRequest {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String       @unique
  title           String
  description     String?
  status          TradeStatus  @default(PENDING)
  
  exporterId      String       @db.Uuid
  exporter        User         @relation("ExporterRequests", fields: [exporterId], references: [id])
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  quotes          LogisticsQuote[]
  documents       Document[]
}

model LogisticsQuote {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  price          Decimal      @db.Decimal(10, 2)
  currency       String       @default("USD")
  estimatedDays  Int
  notes          String?
  
  logisticsId    String       @db.Uuid
  logistics      User         @relation(fields: [logisticsId], references: [id])
  
  tradeRequestId String       @db.Uuid
  tradeRequest   TradeRequest @relation(fields: [tradeRequestId], references: [id])

  isAccepted     Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Document {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  fileUrl        String
  type           DocumentType
  isApproved     Boolean      @default(false)
  
  uploadedById   String       @db.Uuid
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  tradeRequestId String       @db.Uuid
  tradeRequest   TradeRequest @relation(fields: [tradeRequestId], references: [id])

  createdAt      DateTime     @default(now())
}
